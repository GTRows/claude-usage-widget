{
  "name": "claude-usage-widget",
  "version": "1.12.0-gtrows.1",
  "description": "Desktop widget for Claude.ai usage monitoring — GTRows fork",
  "main": "main.js",
  "bin": {
    "claude-usage": "bin/cli.js"
  },
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "dev": "cross-env NODE_ENV=development electron .",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "test": "vitest run",
    "test:watch": "vitest",
    "cli": "node bin/cli.js"
  },
  "keywords": [
    "claude",
    "usage",
    "widget",
    "electron"
  ],
  "author": {
    "name": "GTRows",
    "email": "aciroglu.fatih@gmail.com"
  },
  "contributors": [
    "Slavomir Durej (original author)"
  ],
  "license": "MIT",
  "copyright": "Copyright © 2026 GTRows / aciro — originally © 2025 Slavomir Durej",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "cross-env": "^7.0.3",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "electron-store": "^8.1.0"
  },
  "build": {
    "appId": "com.gtrows.claudewidget",
    "productName": "Claude-Usage-Widget",
    "copyright": "Copyright © 2026 GTRows / aciro — originally © 2025 Slavomir Durej",
    "publish": null,
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/icon.ico"
    },
    "portable": {
      "artifactName": "${productName}-${version}-win-portable.${ext}",
      "unpackDirName": "claude-usage-widget"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "artifactName": "${productName}-${version}-win-Setup.${ext}"
    },
    "files": [
      "**/*",
      "!**/*.ts",
      "!*.md"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": {
        "teamId": "X84UXCNLPX"
      },
      "extendInfo": {
        "NSHumanReadableCopyright": "Copyright © 2026 GTRows / aciro — originally © 2025 Slavomir Durej"
      }
    },
    "dmg": {
      "artifactName": "${productName}-${version}-macOS-${arch}.dmg"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "rpm",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "pacman",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "tar.gz",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/logo.png",
      "category": "Utility",
      "maintainer": "GTRows <aciroglu.fatih@gmail.com>",
      "artifactName": "${productName}-${version}-linux-${arch}.${ext}"
    }
  }
}
